<div id="entry_<%= entry.id %>_status" class="flex items-center gap-1 text-xs">
  <% case status.to_s %>
  <% when "pending" %>
    <span class="text-yellow-500">&#9202;</span>
    <span class="text-yellow-600">Queued</span>
  <% when "processing" %>
    <span class="animate-spin text-blue-500">&#8635;</span>
    <span class="text-blue-600"><%= message || "Processing..." %></span>
  <% when "completed" %>
    <span class="text-green-500">&#10003;</span>
    <span class="text-green-600"><%= message || "Done" %></span>
  <% when "failed" %>
    <span class="text-red-500">&#10007;</span>
    <span class="text-red-600"><%= message || "Failed" %></span>
  <% end %>
</div>
