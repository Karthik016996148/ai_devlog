<%= form_with(model: entry, class: "space-y-6") do |f| %>
  <% if entry.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <h3 class="text-sm font-medium text-red-800"><%= pluralize(entry.errors.count, "error") %> prevented this entry from being saved:</h3>
      <ul class="mt-2 list-disc pl-5 text-sm text-red-700">
        <% entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "e.g., Fix N+1 query in UserController" %>
  </div>

  <div>
    <%= f.label :entry_type, "Type", class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :entry_type, Entry.entry_types.keys.map { |t| [t.humanize, t] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>

  <div data-controller="markdown-preview">
    <div class="flex items-center justify-between mb-1">
      <%= f.label :content, class: "block text-sm font-medium text-gray-700" %>
      <div class="flex rounded-md overflow-hidden border border-gray-300">
        <button type="button" data-markdown-preview-target="editButton" data-action="click->markdown-preview#showEdit"
                class="px-3 py-1 text-xs font-medium bg-indigo-100 text-indigo-700">Edit</button>
        <button type="button" data-markdown-preview-target="previewButton" data-action="click->markdown-preview#showPreview"
                class="px-3 py-1 text-xs font-medium text-gray-500">Preview</button>
      </div>
    </div>
    <p class="text-xs text-gray-500 mb-1">Supports Markdown. Paste code, error logs, or describe your solution.</p>
    <div data-markdown-preview-target="input">
      <%= f.text_area :content,
          rows: 12,
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono",
          placeholder: "Paste your code, error log, or write your notes here...",
          data: { controller: "auto-resize", action: "input->auto-resize#resize" } %>
    </div>
    <div data-markdown-preview-target="preview" class="hidden mt-1 min-h-[200px] rounded-md border border-gray-300 bg-white p-4 prose prose-sm max-w-none"></div>
  </div>

  <div data-controller="tag-input">
    <%= f.label :manual_tags, "Tags (optional)", class: "block text-sm font-medium text-gray-700" %>
    <p class="text-xs text-gray-500 mb-1">AI will also auto-generate tags. Add manual tags separated by commas.</p>
    <div data-tag-input-target="container" class="flex flex-wrap gap-1 mb-2"></div>
    <input type="text"
           data-tag-input-target="input"
           data-action="keydown->tag-input#add"
           class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
           placeholder="Type a tag and press comma or enter...">
    <%= f.hidden_field :manual_tags, value: entry.persisted? ? entry.manual_tags.pluck(:name).join(",") : "", data: { tag_input_target: "hidden" } %>
  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancel", entries_path, class: "text-sm font-medium text-gray-600 hover:text-gray-500" %>
    <%= f.submit entry.persisted? ? "Update Entry" : "Create Entry",
        class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none cursor-pointer" %>
  </div>
<% end %>
