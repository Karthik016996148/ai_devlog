<%= turbo_stream.append "chat_messages" do %>
  <!-- User Question -->
  <div class="flex justify-end">
    <div class="max-w-lg rounded-lg bg-indigo-600 px-4 py-3 text-white">
      <p class="text-sm"><%= @question %></p>
    </div>
  </div>

  <!-- AI Response -->
  <div class="flex justify-start">
    <div class="max-w-2xl rounded-lg bg-white border border-gray-200 px-4 py-3">
      <p class="text-xs font-medium text-gray-500 mb-1">AI DevLog</p>
      <div class="text-sm text-gray-800 prose prose-sm" data-controller="copy-code">
        <%= render_markdown(@answer) %>
      </div>
    </div>
  </div>

  <!-- Sources -->
  <% if @sources.present? && @sources.any? %>
    <details class="bg-white rounded-lg border border-gray-200 p-4">
      <summary class="text-sm font-medium text-gray-700 cursor-pointer hover:text-gray-900">
        Sources (<%= @sources.size %> entries used)
      </summary>
      <div class="mt-3 space-y-2">
        <% @sources.each do |entry| %>
          <%= link_to entry_path(entry), class: "block p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors" do %>
            <div class="flex items-center gap-2">
              <%= entry_type_badge(entry.entry_type) %>
              <span class="text-sm font-medium text-gray-900"><%= entry.title %></span>
            </div>
            <% if entry.ai_summary.present? %>
              <p class="text-xs text-gray-500 mt-1"><%= entry.ai_summary.truncate(120) %></p>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </details>
  <% end %>
<% end %>
