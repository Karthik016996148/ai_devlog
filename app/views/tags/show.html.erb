<div class="space-y-6">
  <div class="flex items-center gap-3">
    <%= link_to "\u2190 All Tags", tags_path, class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
  </div>

  <div class="flex items-center gap-3">
    <h1 class="text-2xl font-bold text-gray-900"><%= @tag.name %></h1>
    <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-600"><%= @tag.entries_count %> <%= "entry".pluralize(@tag.entries_count) %></span>
    <% if @tag.ai_generated? %>
      <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-700">AI-generated</span>
    <% end %>
  </div>

  <div class="space-y-3" id="entries_list">
    <% @entries.each do |entry| %>
      <%= render "entries/entry_card", entry: entry %>
    <% end %>
  </div>
</div>
