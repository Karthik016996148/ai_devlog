<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title>AI DevLog</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <div class="min-h-full">
      <nav class="bg-gray-900 shadow-lg">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 items-center justify-between">
            <div class="flex items-center">
              <div class="shrink-0">
                <%= link_to root_path, class: "flex items-center gap-2" do %>
                  <span class="text-2xl font-bold text-white tracking-tight">AI DevLog</span>
                  <span class="hidden sm:inline-flex items-center rounded-full bg-indigo-500/20 px-2 py-0.5 text-xs font-medium text-indigo-300 ring-1 ring-inset ring-indigo-500/30">RAG</span>
                <% end %>
              </div>
              <div class="ml-10 flex items-baseline space-x-1">
                <%= link_to "Dashboard", root_path,
                    class: "rounded-md px-3 py-2 text-sm font-medium transition-colors #{current_page?(root_path) ? 'bg-gray-700 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" %>
                <%= link_to "Entries", entries_path,
                    class: "rounded-md px-3 py-2 text-sm font-medium transition-colors #{current_page?(entries_path) ? 'bg-gray-700 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" %>
                <%= link_to "Search", search_path,
                    class: "rounded-md px-3 py-2 text-sm font-medium transition-colors #{current_page?(search_path) ? 'bg-gray-700 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" %>
                <%= link_to "Tags", tags_path,
                    class: "rounded-md px-3 py-2 text-sm font-medium transition-colors #{current_page?(tags_path) ? 'bg-gray-700 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white'}" %>
              </div>
            </div>
            <div>
              <%= link_to new_entry_path, class: "inline-flex items-center gap-1 rounded-md bg-indigo-500 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-400 transition-colors" do %>
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                New Entry
              <% end %>
            </div>
          </div>
        </div>
      </nav>

      <% if notice.present? %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
          <div class="rounded-md bg-green-50 border border-green-200 p-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm font-medium text-green-800"><%= notice %></p>
          </div>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
          <div class="rounded-md bg-red-50 border border-red-200 p-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
            </svg>
            <p class="text-sm font-medium text-red-800"><%= alert %></p>
          </div>
        </div>
      <% end %>

      <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8" id="main-content">
        <%= yield %>
      </main>

      <footer class="border-t border-gray-200 mt-12">
        <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
          <p class="text-xs text-gray-400 text-center">AI DevLog &mdash; Built with Rails 7.1, Hotwire, pgvector, and RubyLLM</p>
        </div>
      </footer>
    </div>
  </body>
</html>
