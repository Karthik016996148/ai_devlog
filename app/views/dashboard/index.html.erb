<div class="space-y-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
      <p class="text-sm text-gray-500 mt-1">Your AI-powered developer knowledge base</p>
    </div>
    <%= link_to new_entry_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do %>
      + New Entry
    <% end %>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
    <% [
      ["Total", @entry_counts[:total], "bg-gray-100 text-gray-800", "border-gray-200"],
      ["Code Snippets", @entry_counts[:code_snippets], "bg-purple-100 text-purple-800", "border-purple-200"],
      ["Error Logs", @entry_counts[:error_logs], "bg-red-100 text-red-800", "border-red-200"],
      ["Solutions", @entry_counts[:solutions], "bg-green-100 text-green-800", "border-green-200"],
      ["Notes", @entry_counts[:notes], "bg-blue-100 text-blue-800", "border-blue-200"],
      ["TILs", @entry_counts[:tils], "bg-yellow-100 text-yellow-800", "border-yellow-200"]
    ].each do |label, count, colors, border| %>
      <div class="<%= colors %> border <%= border %> rounded-lg p-4 text-center">
        <p class="text-2xl font-bold"><%= count %></p>
        <p class="text-xs font-medium mt-1"><%= label %></p>
      </div>
    <% end %>
  </div>

  <% if @processing_count > 0 %>
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 flex items-center gap-2">
      <span class="animate-spin text-blue-600">&#8635;</span>
      <span class="text-sm text-blue-800"><%= @processing_count %> <%= "entry".pluralize(@processing_count) %> being processed by AI...</span>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Recent Entries -->
    <div class="lg:col-span-2">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Recent Entries</h2>
        <%= link_to "View all \u2192", entries_path, class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
      </div>

      <div class="space-y-3" id="recent_entries">
        <% if @recent_entries.any? %>
          <% @recent_entries.each do |entry| %>
            <%= render "entries/entry_card", entry: entry %>
          <% end %>
        <% else %>
          <div class="text-center py-12 bg-white rounded-lg border-2 border-dashed border-gray-300">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            <h3 class="mt-2 text-sm font-semibold text-gray-900">No entries yet</h3>
            <p class="mt-1 text-sm text-gray-500">Start building your knowledge base!</p>
            <div class="mt-4">
              <%= link_to "Create your first entry", new_entry_path,
                  class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Tag Cloud -->
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Tag Cloud</h2>
        <div class="bg-white rounded-lg border border-gray-200 p-4">
          <% if @popular_tags.any? %>
            <div class="flex flex-wrap gap-2">
              <% @popular_tags.each do |tag| %>
                <% size = [tag.entries_count, 5].min %>
                <%= link_to tag_path(tag.name),
                    class: "inline-block rounded-full px-3 py-1 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 transition-colors #{'text-xs' if size < 2} #{'text-sm' if size >= 2 && size < 4} #{'text-base font-medium' if size >= 4}" do %>
                  <%= tag.name %>
                  <span class="text-indigo-400 text-xs">(<%= tag.entries_count %>)</span>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 text-sm">Tags will appear here after AI processes your entries.</p>
          <% end %>
        </div>
      </div>

      <!-- Quick Actions -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Quick Actions</h3>
        <div class="space-y-2">
          <%= link_to new_entry_path, class: "block w-full text-left rounded-lg border border-gray-200 bg-white p-3 hover:bg-gray-50 hover:border-indigo-300 transition-all" do %>
            <span class="text-sm font-medium text-gray-900">+ New Entry</span>
            <span class="block text-xs text-gray-500 mt-1">Add code, errors, solutions, or notes</span>
          <% end %>
          <%= link_to search_path, class: "block w-full text-left rounded-lg border border-gray-200 bg-white p-3 hover:bg-gray-50 hover:border-indigo-300 transition-all" do %>
            <span class="text-sm font-medium text-gray-900">Ask Your Knowledge Base</span>
            <span class="block text-xs text-gray-500 mt-1">Search with AI-powered RAG</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
